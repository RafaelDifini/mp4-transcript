# Modelo Whisper a usar
# Opções: tiny | base | small | medium | large-v3
# tiny   → ~75MB,  mais rápido, menos preciso
# base   → ~150MB, bom equilíbrio (padrão)
# small  → ~500MB, melhor qualidade
# medium → ~1.5GB, ótimo para PT-BR
# large-v3 → ~3GB, máxima qualidade
WHISPER_MODEL=base

# Caminho do executável Python (ajuste se usar venv)
# Exemplos:
#   Windows (venv): .venv\Scripts\python.exe
#   macOS/Linux (venv): .venv/bin/python
#   Sistema: python3
PYTHON_EXECUTABLE=python
